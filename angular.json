{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "elite-group-web": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/web",
      "sourceRoot": "apps/web/src",
      "prefix": "eg",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/web",
            "index": "apps/web/src/index.html",
            "browser": "apps/web/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/web/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/web/src/assets",
                "output": "assets"
              }
            ],
            "styles": ["apps/web/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "700kB",
                  "maximumError": "1MB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "elite-group-web:build:production"
            },
            "development": {
              "buildTarget": "elite-group-web:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "apps/web/src/test.ts",
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "apps/web/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/web/src/assets",
                "output": "assets"
              }
            ],
            "styles": ["apps/web/src/styles.css"]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
